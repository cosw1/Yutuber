# Variables de Entorno - Yutuber Backend

# ===== SERVIDOR =====
PORT=5000
NODE_ENV=development

# ===== YOUTUBE API =====
YOUTUBE_API_KEY=tu_clave_youtube_aqui

# ===== SPOTIFY API =====
SPOTIFY_CLIENT_ID=tu_spotify_client_id
SPOTIFY_CLIENT_SECRET=tu_spotify_client_secret

# ===== FIREBASE =====
FIREBASE_PROJECT_ID=tu_proyecto_firebase
FIREBASE_PRIVATE_KEY=tu_private_key_firebase
FIREBASE_CLIENT_EMAIL=tu_email_firebase

# ===== JWT =====
JWT_SECRET=tu_secreto_jwt_muy_seguro_aqui
JWT_EXPIRE=7d

# ===== BASE DE DATOS =====
DATABASE_URL=mongodb://localhost:27017/yutuber
# O para Firebase Firestore, usa las variables de Firebase arriba

# ===== CORS =====
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# ===== URLS =====
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
